# ──────────────────────────────────────────────
# clew-orc configuration
# Copy to .env and customize:
#   cp .env.example .env
# ──────────────────────────────────────────────

# Broker port (default: 7899)
CLEW_ORC_PORT=7899

# Bind address (0.0.0.0 = all interfaces, for LAN/public)
CLEW_ORC_HOST=0.0.0.0

# Database path (default: ~/.clew-orc.db)
# CLEW_ORC_DB=/data/clew-orc.db

# Message TTL in hours (0 = never expire, default: 24)
CLEW_ORC_TTL_HOURS=24

# ─── Authentication (required for public internet) ───
# Set a strong random token. All clients must send it as:
#   Authorization: Bearer <token>
# or pass as CLI arg:
#   bun cli.ts remote connect http://your.server:7899 <token>
# CLEW_ORC_TOKEN=your-secret-token-here

# ─── TLS/HTTPS (recommended for public internet) ───
# Provide paths to certificate and key files.
# Generate self-signed: openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes
# CLEW_ORC_TLS_CERT=/path/to/cert.pem
# CLEW_ORC_TLS_KEY=/path/to/key.pem
# CLEW_ORC_TLS_PASS=  # optional passphrase
